{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [{"path": "/api/cleanup", "schedule": "*/15 * * * *"}],
  "functions": {
    "api/ncp-gpu.js": { "maxDuration": 60 },
    "api/cloud.js": { "maxDuration": 60 },
    "api/cleanup.js": { "maxDuration": 60 }
  },
  "headers": [
    {"source": "/jobs", "headers": [{"key": "Cache-Control", "value": "no-store"}]},
    {"source": "/jobs.html", "headers": [{"key": "Cache-Control", "value": "no-store"}]},
    {"source": "/(.*)", "headers": [{"key": "X-Content-Type-Options", "value": "nosniff"}, {"key": "Referrer-Policy", "value": "no-referrer"}]}
  ]
}
