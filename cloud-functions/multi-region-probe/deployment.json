{
  "runtime": "nodejs:22",
  "main": "main",
  "memoryMb": 128,
  "timeoutMs": 10000,
  "platforms": {
    "KR": "classic-or-vpc",
    "SGN": "vpc-required",
    "JPN": "vpc-required"
