{
  "name": "cloud-gpu-runner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "npm run check:secrets && npm run unit:test && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-tests.ps1",
    "check:env": "node scripts/check-env.mjs",
    "check:env:naver": "node scripts/check-env.mjs naver",
    "check:env:kakao": "node scripts/check-env.mjs kakao",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:safety": "npm run check:secrets && npm run check:env:naver",
    "ncp:smoke": "node scripts/ncp-smoke-test.mjs",
    "ncp:smoke:execute": "node scripts/ncp-smoke-test.mjs --execute",
    "ncp:cost:snapshot": "node scripts/ncp-cost-snapshot.mjs",
    "ncp:cost:snapshot:execute": "node scripts/ncp-cost-snapshot.mjs --execute",
    "ncp:object-storage:smoke": "node scripts/ncp-object-storage-smoke-test.mjs",
    "ncp:object-storage:smoke:execute": "node scripts/ncp-object-storage-smoke-test.mjs --execute",
    "unit:test": "node --test scripts/*.test.mjs",
    "artifact:test": "node --test scripts/cloud-artifact-publish.test.mjs",
    "artifact:publish": "node scripts/cloud-artifact-publish.mjs",
    "artifact:publish:execute": "node scripts/cloud-artifact-publish.mjs --execute",
    "artifact:verify": "node scripts/cloud-artifact-verify.mjs",
    "artifact:verify:execute": "node scripts/cloud-artifact-verify.mjs --execute",
    "probe:plan": "node scripts/cloud-native-probe-plan.mjs",
    "kakao:token": "node scripts/kakao-token-smoke-test.mjs",
    "kakao:token:execute": "node scripts/kakao-token-smoke-test.mjs --execute"
  },
  "devDependencies": {}
}
