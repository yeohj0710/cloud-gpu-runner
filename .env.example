# Copy this file to .env.local and fill only the providers you actually use.
# Never commit .env.local.

# Naver Cloud Platform
NCP_ACCESS_KEY_ID=
NCP_SECRET_KEY=
NCP_REGION=KR
NCP_API_ENDPOINT=https://ncloud.apigw.ntruss.com

# Optional Naver services. Fill these only when you start using the service.
NCP_OBJECT_STORAGE_ENDPOINT=https://kr.object.ncloudstorage.com
NCP_CLOVASTUDIO_API_KEY=
NCP_CLOVASTUDIO_API_GATEWAY_KEY=

# Kakao Cloud placeholder
KAKAO_CLOUD_ACCESS_KEY_ID=
KAKAO_CLOUD_SECRET_ACCESS_KEY=
KAKAO_CLOUD_REGION=
